@startuml deployment
!theme plain
skinparam backgroundColor white
skinparam defaultFontSize 11
skinparam nodeBorderColor #444
skinparam componentBorderColor #555

title Deployment — Docker Containers per Host

node "Server (RPi 4b)\nserver.ros2.lan" as server {
  component "ros2-master" as sm <<Docker>> #C8E6C9
  component "lerobot_leader\n(feetech_servos)" as sl <<Docker>> #A5D6A7
  component "gps_rtk_base" as sg <<Docker>> #A5D6A7
  component "topic_scraper_api" as ss <<Docker>> #C8E6C9
}

node "Client (RPi 5)\nclient.ros2.lan" as client {
  component "ros2-master" as cm <<Docker>> #BBDEFB
  component "master2master" as cmm <<Docker>> #90CAF9
  component "filter_node" as cf <<Docker>> #90CAF9
  component "lerobot_follower\n(feetech_servos)" as clf <<Docker>> #64B5F6
  component "gps_rtk_rover" as cg <<Docker>> #64B5F6
  component "bno055_imu" as ci <<Docker>> #64B5F6
  component "gripper_uvc_camera" as cc <<Docker>> #64B5F6
  component "rplidar_a1" as cr <<Docker>> #64B5F6
  component "realsense_d435i" as cre <<Docker>> #64B5F6
  component "swerve_drive_servos\n(feetech_servos)" as css <<Docker>> #64B5F6
  component "swerve_controller" as csc <<Docker>> #90CAF9
  component "static_tf_publisher" as ctf <<Docker>> #BBDEFB
  component "robot_localization_ekf" as cekf <<Docker>> #90CAF9
  component "nav2_bringup" as cnav <<Docker>> #90CAF9
  component "test_joint_api" as ct <<Docker>> #90CAF9
  component "topic_scraper_api" as cs <<Docker>> #BBDEFB
  component "haptic_controller\n(disabled)" as ch <<Docker>> #CFD8DC
}

node "Controller (SteamDeck)\ncontroller.ros2.lan" as controller {
  component "steamdeck_ui\n(Python bridge + Electron)" as csd <<Native>> #FFF176
  note right of csd
    No Docker — native app.
    Python rclpy bridge + Electron renderer.
  end note
}

server -[#green]-> client : WiFi (DDS + TCP)
client -[#green]-> controller : WiFi (DDS)

note right of server
  4 containers
  systemd-managed
end note

note right of client
  17 containers
  systemd-managed
end note

@enduml

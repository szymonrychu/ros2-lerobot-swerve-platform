{
  "name": "ros2-steamdeck-ui",
  "version": "0.1.0",
  "description": "SteamDeck Electron UI for ROS2 robotics platform",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig-main.json",
    "build:renderer": "esbuild src/renderer/app.ts --bundle --platform=browser --target=es2020 --outfile=src/renderer/bundle.js --external:electron",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "test": "jest"
  },
  "keywords": ["ros2", "electron", "robotics", "steamdeck"],
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "leaflet": "^1.9.4",
    "uplot": "^1.6.31"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^20.17.30",
    "esbuild": "^0.25.1",
    "electron": "^33.3.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^electron$": "<rootDir>/tests/__mocks__/electron.ts"
    }
  }
}
